{
  "ConnectionStrings": {
    "Default": "Data Source=inspection.db"
  },
  "Mqtt": {
    "Enabled": false,
    "Host": "localhost",
    "Port": 1883,
    "Topic": "factory/pcb/inspections",
    "Username": "",
    "Password": ""
