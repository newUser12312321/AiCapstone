@page "/result-detail"
@page "/result-detail/{InspectionId:long}"
@inject InspectionApiClient CloudApi
@inject IConfiguration Config
@inject IJSRuntime JS

<h1>결과 상세</h1>

@if (_detail is null)
{
    <p>데이터 없음</p>
}
else
{
    <p>#@_detail.Id · @_detail.Result</p>
    @if (string.IsNullOrWhiteSpace(ImageUrl))
    {
        <p>이미지 없음</p>
    }
    else if (_imageLoadFailed)
    {
        <p>이미지 로드 실패(엣지 미실행 또는 경로 오류)</p>
    }
    else
    {
        <div class="viewer" @onclick="() => _zoom = true">
            <img @ref="_imgRef" src="@ImageUrl" @onload="OnLoadAsync" @onerror="() => _imageLoadFailed = true" alt="검사 이미지" />
            <svg viewBox="0 0 @_naturalWidth @_naturalHeight" preserveAspectRatio="none">
                @foreach (var d in _detail.Defects)
                {
                    <rect x="@d.BboxX" y="@d.BboxY" width="@d.BboxWidth" height="@d.BboxHeight" fill="none" stroke="#ef4444" stroke-width="3" />
                }
            </svg>
        </div>
    }
}

@if (_zoom && _detail is not null && !string.IsNullOrWhiteSpace(ImageUrl))
{
    <div class="overlay" @onclick="() => _zoom = false">
        <div class="modal" @onclick:stopPropagation="true">
            <button @onclick="() => _zoom = false">닫기</button>
            <div class="viewer large">
                <img src="@ImageUrl" alt="확대 이미지" />
                <svg viewBox="0 0 @_naturalWidth @_naturalHeight" preserveAspectRatio="none">
                    @foreach (var d in _detail.Defects)
                    {
                        <rect x="@d.BboxX" y="@d.BboxY" width="@d.BboxWidth" height="@d.BboxHeight" fill="none" stroke="#ef4444" stroke-width="3" />
                    }
                </svg>
            </div>
        </div>
    </div>
}

@code {
    [Parameter] public long? InspectionId { get; set; }
    private InspectionSummary? _detail;
    private bool _imageLoadFailed;
    private ElementReference _imgRef;
    private int _naturalWidth = 1920;
    private int _naturalHeight = 1080;
    private bool _zoom;

    private string? ImageUrl => Resolve(_detail?.ImagePath);

    protected override async Task OnParametersSetAsync()
    {
        if (InspectionId.HasValue) _detail = await CloudApi.GetByIdAsync(InspectionId.Value);
        else _detail = (await CloudApi.GetLatestAsync(1)).FirstOrDefault();
    }

    private async Task OnLoadAsync()
    {
        var size = await JS.InvokeAsync<ImageSize>("getImageNaturalSize", _imgRef);
        _naturalWidth = size.Width > 0 ? size.Width : 1920;
        _naturalHeight = size.Height > 0 ? size.Height : 1080;
    }

    private string Resolve(string? p)
    {
        if (string.IsNullOrWhiteSpace(p)) return string.Empty;
        p = p.Replace("\\", "/");
        if (p.StartsWith("http://") || p.StartsWith("https://")) return p;
        if (!p.StartsWith("/")) p = "/" + p;
        var edge = Config["EdgeBaseUrl"] ?? "http://localhost:8000";
        return $"{edge.TrimEnd('/')}{p}";
    }

    private sealed class ImageSize { public int Width { get; set; } public int Height { get; set; } }
}
