@page "/"
@inject EdgeApiClient EdgeApi
@inject InspectionApiClient CloudApi
@inject NavigationManager Nav

<section class="kiosk-page">
    <header class="page-header">
        <div>
            <h1>PCB 검사 키오스크</h1>
            <p>터치로 검사 실행 후 최신 결과를 바로 확인합니다.</p>
        </div>
        <button class="ghost-btn" @onclick="RefreshLatestAsync">새로고침</button>
    </header>

    <div class="main-grid">
        <section class="camera-panel">
            <div class="panel-title">실시간 카메라</div>
            <img src="@EdgeApi.StreamUrl" alt="실시간 카메라 스트림" />
        </section>

        <section class="control-panel">
            <div class="panel-title">검사 제어</div>
            <div class="board-select-row">
                <label class="board-select-label" for="board-preset">PCB 기판명</label>
                <select id="board-preset" class="board-select" @bind="_kioskPreset">
                    <option value="standard">일반검사 (실크인쇄 포함)</option>
                    <option value="gt125a">GT-125A (실크 생략)</option>
                    <option value="gn948x">gn948x (실크 생략)</option>
                </select>
            </div>
            <button class="primary-btn" @onclick="RunInspectionAndGoResultAsync">검사 시작 (1회)</button>
            <button class="secondary-btn" @onclick="StartAutoAsync">자동 검사 시작</button>
            @if (!string.IsNullOrWhiteSpace(_actionMessage))
            {
                <p class="status-message">@_actionMessage</p>
            }
        </section>
    </div>

    <section class="latest-panel">
        <div class="panel-title">최신 검사 결과</div>
        @if (_latest is null)
        {
            <p class="empty">데이터 없음</p>
        }
        else
        {
            <div class="result @(IsPass ? "pass" : "fail")">@_latest.Result</div>
            <div class="meta-grid">
                <div>
                    <span class="meta-label">Device</span>
                    <strong>@_latest.DeviceId</strong>
                </div>
                <div>
                    <span class="meta-label">검사 시간</span>
                    <strong>@_latest.InspectedAt.LocalDateTime.ToString("yyyy-MM-dd HH:mm:ss")</strong>
                </div>
                <div>
                    <span class="meta-label">결함 수</span>
                    <strong>@_latest.DefectCount</strong>
                </div>
            </div>
            <button class="detail-btn" @onclick="GoDetail">결과 상세 보기</button>
        }
    </section>
</section>

@code {
    private InspectionSummary? _latest;
    private string? _actionMessage;
    private string _kioskPreset = "standard";
    private bool IsPass => string.Equals(_latest?.Result, "PASS", StringComparison.OrdinalIgnoreCase);

    protected override async Task OnInitializedAsync() => await RefreshLatestAsync();

    private async Task RunInspectionAndGoResultAsync()
    {
        try
        {
            _actionMessage = null;
            await EdgeApi.TriggerInspectionAsync(_kioskPreset);
            _actionMessage = "검사 완료 화면으로 이동합니다...";
            await Task.Delay(1800);
            await RefreshLatestAsync();

            if (_latest is not null)
            {
                Nav.NavigateTo($"/inspection-complete/{_latest.Id}");
                return;
            }

            _actionMessage = "검사 결과를 찾을 수 없습니다. 다시 시도해 주세요.";
        }
        catch (Exception ex)
        {
            _actionMessage = $"요청 실패: {ex.Message}";
        }
    }
    private async Task StartAutoAsync() => await ExecuteEdgeActionAsync(() => EdgeApi.StartAutoInspectionAsync(), "자동 검사 시작");

    private async Task ExecuteEdgeActionAsync(Func<Task> action, string successMessage)
    {
        try
        {
            _actionMessage = null;
            await action();
            _actionMessage = successMessage;
            await Task.Delay(1500);
            await RefreshLatestAsync();
        }
        catch (Exception ex)
        {
            _actionMessage = $"요청 실패: {ex.Message}";
        }
    }

    private async Task RefreshLatestAsync()
    {
        _latest = (await CloudApi.GetLatestAsync(1)).FirstOrDefault();
    }

    private void GoDetail()
    {
        if (_latest is not null) Nav.NavigateTo($"/result-detail/{_latest.Id}");
    }
}
