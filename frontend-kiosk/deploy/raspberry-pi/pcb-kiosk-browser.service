[Unit]
Description=PCB Kiosk Chromium Browser
After=graphical.target pcb-kiosk-web.service
Wants=graphical.target pcb-kiosk-web.service

[Service]
Type=simple
User=pi
Environment=DISPLAY=:0
Environment=XAUTHORITY=/home/pi/.Xauthority
Environment=KIOSK_URL=http://127.0.0.1:5010
ExecStart=/home/pi/inspection/frontend-kiosk/deploy/raspberry-pi/start-kiosk-browser.sh
Restart=always
RestartSec=3

[Install]
WantedBy=graphical.target
