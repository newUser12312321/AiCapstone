#!/usr/bin/env bash
set -euo pipefail

SERVICES=(
  "pcb-kiosk-web.service"
  "pcb-kiosk-browser.service"
  "pcb-react-kiosk-web.service"
  "pcb-react-kiosk-browser.service"
)

found=()
for svc in "${SERVICES[@]}"; do
  unit_info="$(systemctl list-unit-files "${svc}" --no-legend 2>/dev/null || true)"
  if [ -n "${unit_info}" ]; then
    found+=("${svc}")
  fi
done

if [ "${#found[@]}" -eq 0 ]; then
  echo "No kiosk services found."
  echo "Expected one of: ${SERVICES[*]}"
  exit 1
fi

for svc in "${found[@]}"; do
  echo "Starting ${svc} ..."
  sudo systemctl start "${svc}"
done

echo
echo "Started services:"
for svc in "${found[@]}"; do
  echo "- ${svc}"
done
