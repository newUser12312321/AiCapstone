[Unit]
Description=PCB React Kiosk Chromium Browser
After=graphical.target pcb-react-kiosk-web.service
Wants=graphical.target pcb-react-kiosk-web.service

[Service]
Type=simple
User=pi
Environment=DISPLAY=:0
Environment=XAUTHORITY=/home/pi/.Xauthority
Environment=KIOSK_URL=http://127.0.0.1:4173/
ExecStart=/usr/local/bin/start-react-kiosk-browser.sh
Restart=always
RestartSec=3

[Install]
WantedBy=graphical.target
