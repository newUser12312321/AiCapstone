# vite.config.ts 가 /api·/edge·/captures 를 넘길 대상 (개발 서버 전용)
# frontend/.env 로 복사 후 수정 → npm run dev 재시작
VITE_API_PROXY_TARGET=http://localhost:8080
# GCP VM API만 쓸 때 (이미지 URL도 VM으로 감) — 예: http://34.64.251.53:8080/api
# VITE_API_BASE_URL=http://<VM-IP>:8080/api
# 로컬 PC에서 edge 실행: http://127.0.0.1:8000 / 라즈베리파이: http://<Pi-IP>:8000
VITE_EDGE_CAPTURE_URL=http://127.0.0.1:8000
